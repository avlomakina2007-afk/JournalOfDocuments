<Window x:Class="JournalOfDocuments.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Журнал входящих документов - ООО РЭМ" 
        Height="550" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Регистрация входящих документов" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Таблица документов -->
        <DataGrid x:Name="dgDocuments" Grid.Row="1" AutoGenerateColumns="False" 
                  SelectionMode="Single" SelectionChanged="dgDocuments_SelectionChanged"
                  CanUserAddRows="False" IsReadOnly="False" Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" IsReadOnly="True"/>
                <DataGridTextColumn Header="Вх. №" Binding="{Binding IncomingNumber}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DateReceived, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Отправитель" Binding="{Binding Sender}" Width="150"/>
                <DataGridTextColumn Header="Тема" Binding="{Binding Subject}" Width="250"/>
                <DataGridTextColumn Header="Исполнитель" Binding="{Binding Executor}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма ввода/редактирования -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,10,0,0">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Входящий №:" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtNumber" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Дата:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker x:Name="dpDate" Grid.Row="0" Grid.Column="3" Margin="5"/>

                    <TextBlock Text="Отправитель:" Grid.Row="1" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtSender" Grid.Row="1" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Исполнитель:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtExecutor" Grid.Row="1" Grid.Column="3" Margin="5"/>
                </Grid>

                <TextBlock Text="Тема документа:" Margin="5,0,0,0"/>
                <TextBox x:Name="txtSubject" Height="60" TextWrapping="Wrap" Margin="5"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnAdd" Content="➕ Добавить" Width="100" Margin="5" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="✏️ Редактировать" Width="100" Margin="5" Click="btnEdit_Click" IsEnabled="False"/>
                    <Button x:Name="btnDelete" Content="🗑️ Удалить" Width="100" Margin="5" Click="btnDelete_Click" IsEnabled="False"/>
                    <Button x:Name="btnClear" Content="Очистить форму" Width="100" Margin="5" Click="btnClear_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>